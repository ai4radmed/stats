---
export const prerender = false;

import { supabaseAnon } from '../lib/supabase-server';
import MasterTable from '../components/master/MasterTable.astro';
import '../styles/design-system.css';

// 데이터 수집
const { data: drugs, error: drugsError } = await supabaseAnon
    .from('mfds_radpharm_master')
    .select('*')
    .order('item_name', { ascending: true });

// 동기화 로그 수집
const { data: syncLogs } = await supabaseAnon
    .from('api_sync_log')
    .select('request_count, created_at')
    .order('created_at', { ascending: false });

const latestSync = syncLogs?.[0];
---

<html lang="ko">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width" />
        <title>마스터 리스트 - NM Statistics</title>
        <style>
            body { font-family: 'Pretendard', sans-serif; background-color: var(--gray-50); margin: 0; }
            .container { max-width: 1200px; margin: 0 auto; padding: 2rem; }
            header { margin-bottom: 2rem; }
            h1 { font-size: 2rem; color: var(--primary); margin: 0; }
            .sync-info { font-size: 0.875rem; color: var(--gray-500); margin-top: 0.5rem; }
            .back-link { color: var(--gray-500); text-decoration: none; font-size: 0.875rem; display: block; margin-bottom: 1rem; }
        </style>
    </head>
    <body>
        <div class="container">
            <a href="/" class="back-link">&larr; 메인으로 돌아가기</a>
            <header>
                <h1>방사성의약품 마스터 리스트</h1>
                <div class="sync-info">
                   최종 동기화: {latestSync ? new Date(latestSync.created_at).toLocaleString('ko-KR') : '기록 없음'}
                </div>
            </header>

            <MasterTable drugs={drugs || []} />
        </div>
    </body>
</html>
