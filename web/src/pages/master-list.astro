---
export const prerender = false;

import { supabaseAnon } from '../lib/supabase-server';

// 데이터 수집
const { data: drugs, error: drugsError } = await supabaseAnon
    .from('mfds_radpharm_master')
    .select('*')
    .order('item_name', { ascending: true });

// API 동기화 로그 수집 (전체 호출 횟수 계산을 위해 전체 로드)
const { data: syncLogs, error: logsError } = await supabaseAnon
    .from('api_sync_log')
    .select('request_count, item_count, created_at')
    .order('created_at', { ascending: false });

if (drugsError || logsError) {
    console.error('Data fetch error:', drugsError || logsError);
}

const latestSync = syncLogs?.[0];
const totalRequests = syncLogs?.reduce((sum, log) => sum + (log.request_count || 0), 0) || 0;
const trafficLimit = 10000;
const trafficUsagePercent = Math.min(((totalRequests / trafficLimit) * 100), 100).toFixed(1);

const categories = ["전체", "Generator", "Cold Kit", "Finished"];
---

<html lang="ko">
    <head>
        <meta charset="utf-8" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <meta name="viewport" content="width=device-width" />
        <title>의약품 마스터 리스트 - NM Statistics</title>
        <style>
            :root {
                --primary: #1e40af;
                --primary-light: #eff6ff;
                --gray-50: #f9fafb;
                --gray-100: #f3f4f6;
                --gray-200: #e5e7eb;
                --gray-500: #6b7280;
                --gray-800: #1f2937;
            }

            body {
                font-family: 'Pretendard', sans-serif;
                background-color: var(--gray-50);
                margin: 0;
                color: var(--gray-800);
            }

            .container {
                max-width: 1400px;
                margin: 0 auto;
                padding: 2rem;
            }

            header {
                margin-bottom: 2rem;
                display: flex;
                flex-direction: column;
                gap: 1rem;
            }

            h1 {
                margin: 0;
                font-size: 2rem;
                color: var(--primary);
            }

            .card {
                background: white;
                border-radius: 1rem;
                box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);
                border: 1px solid var(--gray-200);
                overflow: hidden;
            }

            .table-container {
                overflow-x: auto;
            }

            table {
                width: 100%;
                border-collapse: collapse;
                text-align: left;
            }

            th {
                background-color: var(--gray-100);
                padding: 1rem;
                font-weight: 600;
                font-size: 0.875rem;
                color: var(--gray-500);
                text-transform: uppercase;
                letter-spacing: 0.05em;
            }

            td {
                padding: 1rem;
                border-bottom: 1px solid var(--gray-100);
                font-size: 0.9375rem;
            }

            tr:hover {
                background-color: var(--gray-50);
            }

            .badge {
                display: inline-block;
                padding: 0.25rem 0.625rem;
                border-radius: 9999px;
                font-size: 0.75rem;
                font-weight: 500;
            }

            .badge-generator { background: #fee2e2; color: #991b1b; }
            .badge-kit { background: #fef3c7; color: #92400e; }
            .badge-finished { background: #dcfce7; color: #166534; }

            .atc-code {
                font-family: monospace;
                background: var(--gray-100);
                padding: 0.2rem 0.4rem;
                border-radius: 0.25rem;
            }

            .nav-link {
                color: var(--gray-500);
                text-decoration: none;
                font-size: 0.875rem;
                margin-bottom: 0.5rem;
                display: inline-block;
            }

            .nav-link:hover {
                text-decoration: underline;
            }

            .status-grid {
                display: grid;
                grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
                gap: 1rem;
                margin-bottom: 2rem;
            }

            .status-card {
                background: white;
                padding: 1.25rem;
                border-radius: 0.75rem;
                border: 1px solid var(--gray-200);
                box-shadow: 0 1px 2px 0 rgba(0, 0, 0, 0.05);
            }

            .status-label {
                font-size: 0.75rem;
                color: var(--gray-500);
                text-transform: uppercase;
                letter-spacing: 0.05em;
                margin-bottom: 0.5rem;
                display: block;
            }

            .status-value {
                font-size: 1.25rem;
                font-weight: 700;
                color: var(--primary);
            }
        </style>
    </head>
    <body>
        <div class="container">
            <a href="/" class="nav-link">&larr; 메인으로 돌아가기</a>
            <header>
                <h1>방사성의약품 마스터 리스트</h1>
                <p>식약처(MFDS) 허가 정보를 기반으로 구축된 핵의학 의약품 통계 마스터 데이터입니다.</p>
            </header>

            <div class="status-grid">
                <div class="status-card">
                    <span class="status-label">최종 동기화</span>
                    <span class="status-value">
                        {latestSync ? new Date(latestSync.created_at).toLocaleString('ko-KR') : '기록 없음'}
                    </span>
                </div>
                <div class="status-card">
                    <span class="status-label">API 호출 횟수 (최종)</span>
                    <span class="status-value">{latestSync?.request_count || 0}회</span>
                </div>
                <div class="status-card">
                    <span class="status-label">트래픽 사용량 (제한 10,000)</span>
                    <span class="status-value">{totalRequests.toLocaleString()} / 10,000 ({trafficUsagePercent}%)</span>
                    <div style="width: 100%; height: 4px; background: var(--gray-100); border-radius: 2px; margin-top: 0.5rem; overflow: hidden;">
                        <div style={`width: ${trafficUsagePercent}%; height: 100%; background: ${parseFloat(trafficUsagePercent) > 80 ? '#ef4444' : 'var(--primary)'}; transition: width 0.3s ease;`}></div>
                    </div>
                </div>
            </div>

            <div class="card">
                <div class="table-container">
                    <table>
                        <thead>
                            <tr>
                                <th>No.</th>
                                <th>품목코드</th>
                                <th>제품명</th>
                                <th>업체명</th>
                                <th>카테고리</th>
                                <th>ATC 코드</th>
                                <th>주요성분</th>
                                <th>허가일자</th>
                                <th>취소일자</th>
                                <th>생성일시</th>
                                <th>수정일시</th>
                                <th style="width: 100px;">EDI 코드</th>
                            </tr>
                        </thead>
                        <tbody>
                             {drugs?.map((drug, index) => (
                                <tr>
                                    <td style="color: var(--gray-500);">{index + 1}</td>
                                    <td class="atc-code">{drug.item_seq}</td>
                                    <td style="font-weight: 500; min-width: 200px;">{drug.item_name}</td>
                                    <td style="color: var(--gray-500); min-width: 150px;">{drug.entp_name}</td>
                                    <td>
                                        <span class={`badge badge-${drug.category?.toLowerCase()?.replace(' ', '-')}`}>
                                            {drug.category}
                                        </span>
                                    </td>
                                    <td><span class="atc-code">{drug.atc_code}</span></td>
                                    <td style="font-size: 0.8125rem; max-width: 250px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis;" title={drug.main_item_ingr}>
                                        {drug.main_item_ingr}
                                    </td>
                                    <td style="white-space: nowrap;">{drug.item_permit_date}</td>
                                    <td style="white-space: nowrap;">{drug.cancel_date || '-'}</td>
                                    <td style="font-size: 0.75rem; color: var(--gray-500); white-space: nowrap;">
                                        {drug.created_at ? new Date(drug.created_at).toLocaleDateString() : '-'}
                                    </td>
                                    <td style="font-size: 0.75rem; color: var(--gray-500); white-space: nowrap;">
                                        {drug.updated_at ? new Date(drug.updated_at).toLocaleDateString() : '-'}
                                    </td>
                                    <td style="font-size: 0.8125rem; color: var(--gray-500); width: 100px;">{drug.edi_code || '-'}</td>
                                </tr>
                            ))}
                            {(!drugs || drugs.length === 0) && (
                                <tr>
                                    <td colspan="12" style="text-align: center; padding: 3rem; color: var(--gray-500);">
                                        데이터를 불러오는 중이거나 데이터가 없습니다.
                                    </td>
                                </tr>
                            )}
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </body>
</html>
