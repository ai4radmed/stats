---
interface Props {
  performanceData: any[];
}

const { performanceData } = Astro.props;
---

<div class="interactive-table-container">
  <div class="filters-bar">
    <input type="text" id="searchItem" placeholder="제품명 검색..." class="filter-input" />
    <select id="filterYear" class="filter-input">
      <option value="">모든 연도</option>
      <option value="2024">2024년</option>
      <option value="2023">2023년</option>
      <option value="2022">2022년</option>
    </select>
    <select id="filterPart" class="filter-input">
      <option value="">모든 구분</option>
      <option value="생산">생산</option>
      <option value="수입">수입</option>
    </select>
  </div>

  <div class="table-wrapper card">
    <table id="performanceTable">
      <thead>
        <tr>
          <th data-sort="year" class="sortable">연도 ↕</th>
          <th data-sort="item_name" class="sortable">제품명 ↕</th>
          <th data-sort="entp_name" class="sortable">업체명 ↕</th>
          <th data-sort="result_part" class="sortable">구분 ↕</th>
          <th data-sort="amount" class="sortable" style="text-align: right;">금액(원) ↕</th>
        </tr>
      </thead>
      <tbody>
        {performanceData.map((row) => (
          <tr class="data-row" 
              data-year={row.year} 
              data-name={row.item_name} 
              data-part={row.result_part}
              data-amount={row.amount}>
            <td>{row.year}</td>
            <td style="font-weight: 600;">{row.item_name}</td>
            <td style="color: var(--gray-500);">{row.entp_name}</td>
            <td>
              <span class={`badge ${row.result_part === '생산' ? 'badge-prod' : 'badge-imp'}`}>
                {row.result_part}
              </span>
            </td>
            <td style="text-align: right; font-family: monospace;">
              {row.amount?.toLocaleString()}
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>

<style>
  .interactive-table-container { display: flex; flex-direction: column; gap: 1rem; }
  .filters-bar { display: flex; gap: 0.75rem; flex-wrap: wrap; }
  .filter-input {
    padding: 0.625rem 1rem;
    border: 1px solid var(--gray-200);
    border-radius: 0.5rem;
    font-size: 0.875rem;
    outline: none;
    transition: border-color 0.2s;
  }
  .filter-input:focus { border-color: var(--primary); box-shadow: 0 0 0 3px rgba(30, 64, 175, 0.1); }
  .sortable { cursor: pointer; user-select: none; }
  .sortable:hover { background-color: var(--gray-100); color: var(--primary); }
  .badge-prod { background: #dcfce7; color: #166534; }
  .badge-imp { background: #eff6ff; color: #1e40af; }
</style>

<script>
  // Simple client-side sorting and filtering logic
  const table = document.getElementById('performanceTable');
  const searchInput = document.getElementById('searchItem');
  const yearFilter = document.getElementById('filterYear');
  const partFilter = document.getElementById('filterPart');
  const rows = Array.from(document.querySelectorAll('.data-row'));

  function updateTable() {
    const searchText = searchInput.value.toLowerCase();
    const year = yearFilter.value;
    const part = partFilter.value;

    rows.forEach(row => {
      const matchSearch = row.dataset.name.toLowerCase().includes(searchText);
      const matchYear = !year || row.dataset.year === year;
      const matchPart = !part || row.dataset.part === part;
      row.style.display = (matchSearch && matchYear && matchPart) ? '' : 'none';
    });
  }

  [searchInput, yearFilter, partFilter].forEach(el => el?.addEventListener('input', updateTable));

  // Sorting logic (can be expanded if needed)
  document.querySelectorAll('.sortable').forEach(th => {
    th.addEventListener('click', () => {
      const col = th.dataset.sort;
      const order = th.dataset.order === 'asc' ? 'desc' : 'asc';
      th.dataset.order = order;
      
      const visibleRows = rows.filter(r => r.style.display !== 'none');
      visibleRows.sort((a, b) => {
        let valA = a.dataset[col === 'item_name' ? 'name' : col];
        let valB = b.dataset[col === 'item_name' ? 'name' : col];
        
        if (col === 'amount') { valA = parseInt(valA); valB = parseInt(valB); }
        return order === 'asc' ? (valA > valB ? 1 : -1) : (valA < valB ? 1 : -1);
      });
      
      const tbody = table.querySelector('tbody');
      visibleRows.forEach(row => tbody.appendChild(row));
    });
  });
</script>
