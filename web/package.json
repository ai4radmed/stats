{
  "name": "ai4radmed-stats",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "test": "npm run check && npm run lint && npm run test:unit",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.3.13",
    "@astrojs/rss": "^4.0.15",
    "@astrojs/sitemap": "^3.7.0",
    "@astrojs/vercel": "^9.0.4",
    "@nanostores/persistent": "^1.2.0",
    "@supabase/ssr": "^0.8.0",
    "@supabase/supabase-js": "^2.91.1",
    "@vite-pwa/astro": "^1.2.0",
    "astro": "^5.16.15",
    "nanostores": "^1.1.0",
    "remark-gfm": "^4.0.1",
    "sharp": "^0.34.3"
  },
  "lint-staged": {
    "*.{ts,astro}": [
      "eslint --fix --max-warnings=-1"
    ],
    "*.{ts,astro,css,json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.6",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.58.2",
    "@vitest/coverage-v8": "^4.0.18",
    "eslint": "^10.0.0",
    "eslint-plugin-astro": "^1.6.0",
    "happy-dom": "^20.6.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.55.0",
    "vitest": "^4.0.18"
  }
}
